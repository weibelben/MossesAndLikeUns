---
import Base from '../layouts/Base.astro';
---

<Base title="About">
  <section class="card about-card">
    <h1>About this project</h1>
    <p>
      This frontend is designed to feel like a calm, community-driven field guide — grounded in
      the same warm, nature-forward spirit that makes platforms like iNaturalist so engaging.
    </p>
    <ul>
      <li>Clean, readable layout with strong visual hierarchy</li>
      <li>Green palette inspired by moss, leaves, and field observation</li>
      <li>Simple navigation for a lightweight, content-first experience</li>
    </ul>
  </section>
</Base>

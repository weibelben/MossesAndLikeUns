---
import Base from "../layouts/Base.astro";
---
<Base title="Home">
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Field notes • Bryophytes • Community science</p>
      <h1>Discover the small worlds growing just outside your door.</h1>
      <p>
        This site brings together a calm, naturalist-inspired experience for sharing mosses,
        lichens, and the habitats that support them.
      </p>
      <div class="hero-actions">
        <a class="button primary" href="/about">Learn more</a>
        <a class="button secondary" href="/">Explore observations</a>
      </div>
    </div>

    <div class="hero-panel">
      <div class="stat-card">
        <strong>120+</strong>
        <span>observations</span>
      </div>
      <div class="stat-card">
        <strong>18</strong>
        <span>species logged</span>
      </div>
      <div class="stat-card">
        <strong>4</strong>
        <span>habitats tracked</span>
      </div>
    </div>
  </section>

  <section class="feature-grid">
    <article class="card">
      <h2>Observe</h2>
      <p>Capture what you find in the field with a simple, welcoming interface.</p>
    </article>
    <article class="card">
      <h2>Learn</h2>
      <p>Build familiarity with local flora and the stories behind each patch of green.</p>
    </article>
    <article class="card">
      <h2>Share</h2>
      <p>Turn notes into a living record of biodiversity and seasonal change.</p>
    </article>
  </section>
</Base>